# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend
frontend/node_modules/
frontend/dist/

# Local secrets
.env
*.env
!.env.example

# Generated Word artifacts and Office lock files
*.docx
*.log.json
