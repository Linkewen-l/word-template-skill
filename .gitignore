!templates/
!templates/**/*.docx

# Keep project examples and source tracked explicitly
!word_template_skill/
!word_template_skill/**
word_template_skill/.env
word_template_skill/*.env
word_template_skill/**/__pycache__/
word_template_skill/**/*.py[cod]
